# ---------------------------------------------------------------------------
# DB Backend selector
#   neon   — all SQL via Neon HTTPS REST API (default; works behind corporate proxy)
#   sqlite — local SQLite file (offline dev / unit tests)
# ---------------------------------------------------------------------------
DB_BACKEND=sqlite

# Neon PostgreSQL connection strings
# channel_binding=require is Neon's default; stripped in database.py

# neondb_owner credentials — DDL / Alembic migrations (CREATE/ALTER/DROP)
NEON_DDL_CONN_STR=postgresql://neondb_owner:npg_dnSNjM2XOw1e@ep-rough-morning-a1v4c224.ap-southeast-1.aws.neon.tech/perfmdb?sslmode=require
NEON_DDL_PGUSER=neondb_owner
NEON_DDL_PGPASSWORD=npg_dnSNjM2XOw1e

# perfmdb_owner credentials — App runtime (DML only: SELECT/INSERT/UPDATE/DELETE)
DATABASE_URL=postgresql://perfmdb_owner:npg_7crZ0jdPpmOh@ep-rough-morning-a1v4c224-pooler.ap-southeast-1.aws.neon.tech/perfmdb?sslmode=require&channel_binding=require
PGHOST=ep-rough-morning-a1v4c224-pooler.ap-southeast-1.aws.neon.tech
PGDATABASE=perfmdb
PGUSER=perfmdb_owner
PGPASSWORD=npg_7crZ0jdPpmOh

# NEON_SQL_PASS: password for the Neon HTTP SQL endpoint
# (ep-rough-morning-a1v4c224.ap-southeast-1.aws.neon.tech/sql — NOT blocked by Zscaler)
# MUST be reset via Neon Console UI: Roles → perfmdb_owner → Reset password
# SQL-created passwords don't use SCRAM-SHA-256 and will fail with "missing auth credentials"
# After reset, paste the new password here. Also update PGPASSWORD and DATABASE_URL above.
NEON_SQL_PASS=npg_7crZ0jdPpmOh


# Neon REST API key - create one at: https://console.neon.tech/app/settings/api-keys
# Used for management operations over HTTPS (bypasses port 5432 restrictions)
NEON_ORG_ID=org-bitter-tree-45878282
NEON_API_KEY=napi_92akmtzkdj99gwfj8lv0hafhknmw55zmgwyt4dl5iyz86kg088yi5l222uea5kfv

# branch labels (informational, used by dev tooling)
NEON_DEV_BRANCH=develop
NEON_PROD_BRANCH=production

# JWT signing secret — change this before deploying!
# Generate: uv run python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=e93adaf91df5c2f67b13033c4b6141debaeef3fab7a3b2d9aec71e57db392e40
JWT_EXPIRE_MINUTES=1440

# For testing
TEST_ADMIN_USERNAME=testAdmin
TEST_ADMIN_PASSWORD=testAdmin

TEST_USER_USERNAME=testUser
TEST_USER_PASSWORD=testUser
