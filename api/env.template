# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
#   cp api/env.template api/.env
#
# All variables have safe defaults — this file is optional for local dev.
# ---------------------------------------------------------------------------

# SQLite database path (default: db/master.db relative to project root)
# SQLITE_PATH=db/master.db

# JWT signing secret — required for production/staging deployments.
# Generate: uv run python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=<GENERATE_WITH_COMMAND_ABOVE>

# JWT token lifetime in minutes (default: 1440 = 24 h)
# JWT_EXPIRE_MINUTES=1440

# Test credentials used by the UI smoke test (default: testAdmin / testAdmin)
# TEST_ADMIN_USERNAME=testAdmin
# TEST_ADMIN_PASSWORD=testAdmin
